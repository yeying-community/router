# 复制为 config.yaml 后按需修改:
# cp config.yaml.template config.yaml

server:
  # 监听端口，可被 --port 覆盖
  port: 3011
  # debug / release / test
  gin_mode: release
  # 日志目录，可被 --log-dir 覆盖
  log_dir: ./logs
  # 对外访问地址，用于密码找回、充值回调等需要拼接公网 URL 的场景
  address: ""

database:
  # 仅支持 PostgreSQL
  # 本地 Docker Compose 默认: /Users/liuxin2/Workspace/opensource/deployer/middleware/postgresql/.env
  # POSTGRES_USER=postgres POSTGRES_PASSWORD=postgres POSTGRES_DB=postgres POSTGRES_PORT=5432
  sql_dsn: "postgres://postgres:postgres@127.0.0.1:5432/postgres?sslmode=disable"
  # 日志库 DSN，留空则复用 sql_dsn
  log_sql_dsn: ""
  max_idle_conns: 100
  max_open_conns: 1000
  max_lifetime_seconds: 60

redis:
  # 留空时不启用 Redis
  # 单机示例: redis://:password@127.0.0.1:6379/0
  conn_string: ""
  # 哨兵模式可填写主节点名，conn_string 为逗号分隔地址
  master_name: ""
  password: ""

node:
  # master / slave
  type: master
  polling_interval_seconds: 0

cache:
  memory_cache_enabled: false
  sync_frequency_seconds: 600
  channel_test_frequency: 0
  batch_update_enabled: false
  batch_update_interval_seconds: 5

auth:
  # 必须替换为随机字符串
  session_secret: random_string
  auto_register_enabled: true
  wallet_jwt_secret: ""
  wallet_jwt_fallback_secrets: []
  wallet_jwt_expire_hours: 72
  wallet_refresh_expire_hours: 720
  wallet_nonce_ttl_minutes: 10
  wallet_refresh_cookie_domain: ""
  wallet_refresh_cookie_secure: false
  wallet_refresh_cookie_samesite: lax

cors:
  # 为空表示不限制（回显 Origin）
  # 示例:
  # - https://router.example.com
  # - http://localhost:5181
  allowed_origins: []

ucan:
  # 公网部署建议显式设置 did:web:<your-domain>
  aud: ""
  # 推荐资源语义: app:<scope>:<appId>（如 app:all:chat.example.com）
  # 历史兼容: app:<appId> / llm:<host> / router:llm / profile
  resource: ""
  # 推荐动作: invoke / read / write
  action: invoke

feature:
  debug: false
  debug_sql: false
  disable_openai_compat: false
  # slave 节点可配置前端跳转地址
  frontend_base_url: ""

operation:
  # 支付接入模式：
  # - redirect: 旧模式，router 直接拼接收银台 URL 参数并跳转
  # - api: 新模式，router 服务端直连 yeying-room 的 create API，再跳转返回的 cashier_url
  # 留空时：若配置了 top_up_api_create_url 则按 api，否则按 redirect
  top_up_mode: ""
  # redirect 模式的收银台地址；api 模式下可留空。
  # 如果配置的是 .../api.external_pay/cashier，且 top_up_mode=api 时，系统也可据此自动推导 create API 地址。
  top_up_link: ""
  # api 模式的下单接口地址，例如：
  # https://www.tidukongjian.com/addons/ymq_zixishi/public/index.php/addons/ymqzixishi/api.external_pay/create
  top_up_api_create_url: ""
  # api 模式的查单接口地址；留空时会优先从 create URL 自动推导为 .../query
  top_up_api_query_url: ""
  # api 模式请求参数中的 uniacid
  top_up_api_uniacid: 1
  # api 模式的外部商户标识，需与 yeying-room 的 external_pay_merchants 配置一致
  top_up_merchant_app: router
  # api 模式请求超时秒数
  top_up_api_timeout_seconds: 15
  # 外部支付签名密钥；创建充值/购卡订单时使用
  top_up_sign_secret: ""
  # 外部支付回调鉴权令牌；仅影响支付成功后的回调发货，不再用于前端按钮可用性判定
  top_up_callback_token: ""
  # 用户工作区聊天入口；为空则不展示聊天菜单
  chat_link: ""

relay:
  timeout_seconds: 0
  proxy: ""
  user_content_request_proxy: ""
  user_content_request_timeout_seconds: 30
  gemini_safety_setting: BLOCK_NONE
  gemini_version: v1
  enforce_include_usage: false
  test_prompt: "Output only your specific model name with no additional text."

rate_limit:
  global_api_rate_limit: 480
  global_api_rate_limit_duration_seconds: 180
  global_web_rate_limit: 240
  global_web_rate_limit_duration_seconds: 180

metrics:
  enabled: false
  queue_size: 10
  success_rate_threshold: 0.8
  success_chan_size: 1024
  fail_chan_size: 128

bootstrap:
  initial_root_token: ""
  initial_root_access_token: ""
  # 配置为拥有系统级用户管理权限的钱包地址，支持多个地址用英文逗号分隔；
  # 留空则不显示用户管理页面，也不授予相关权限
  root_wallet_address: ""

logging:
  only_one_log_file: false
  # 单个日志文件达到该大小（MB）后轮转
  rotate_max_size_mb: 100
  # 保留的历史文件数量，0 表示不限制
  rotate_max_backups: 10
  # 保留的历史文件天数，0 表示不按天删除
  rotate_max_age_days: 14
  # 是否压缩历史日志
  rotate_compress: false
